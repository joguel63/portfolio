---
import type { HomeAboutContent } from '../../lib/content/types/content';

import Heading from '../atoms/Heading.astro';
import Text from '../atoms/Text.astro';

interface Props {
  about: HomeAboutContent;
}

const { about } = Astro.props as Props;
---

<section id="sobre-mi" class="section section--about">
  <div class="container about about--stitch">
    <div class="about__media-column">
      <div class="about__portrait-shell">
        <span class="about__portrait-halo" aria-hidden="true"></span>
        <figure class="media-frame about__portrait">
          {about.image ? (
            <img
              src={about.image}
              alt={about.imageAlt}
              loading="lazy"
              decoding="async"
            />
          ) : (
            <span class="fallback-mark" aria-hidden="true">MM</span>
          )}
        </figure>
      </div>
    </div>

    <div class="about__content-column">
      <div class="about__heading-block">
        <span class="about__eyebrow">{about.title}</span>
        <Heading as="h3" size="xl" className="about__heading">{about.heading}</Heading>
      </div>

      <div class="about__body">
        {about.body.map((paragraph) => <Text size="lead">{paragraph}</Text>)}
      </div>

      <div class="about__stats about__stats--stitch" aria-label={about.title}>
        {about.stats.map((stat) => (
          <div class="about__stat-inline">
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
