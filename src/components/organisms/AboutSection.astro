---
import type { HomeAboutContent } from '../../lib/content/types/content';

import Heading from '../atoms/Heading.astro';

interface Props {
  about: HomeAboutContent;
}

const { about } = Astro.props as Props;
---

<section id="sobre-mi" class="section section--about">
  <div class="container about about--stitch" data-about-root>
    <div class="about__media-column" data-about-media>
      <div class="about__portrait-shell">
        <span class="about__portrait-halo" aria-hidden="true" data-about-halo></span>
        <figure class="media-frame about__portrait" data-about-image>
          {about.image ? (
            <img
              src={about.image}
              alt={about.imageAlt}
              loading="lazy"
              decoding="async"
            />
          ) : (
            <span class="fallback-mark" aria-hidden="true">MM</span>
          )}
        </figure>
      </div>
    </div>

    <div class="about__content-column">
      <div class="about__heading-block" data-about-heading-group>
        <span class="about__eyebrow" data-about-eyebrow>{about.title}</span>
        <div data-about-title>
          <Heading as="h3" size="xl" className="about__heading">{about.heading}</Heading>
        </div>
      </div>

      <div class="about__body" data-about-body>
        {about.body.map((paragraph) => (
          <p class="text text--lead" data-about-paragraph>{paragraph}</p>
        ))}
      </div>

      <div class="about__stats about__stats--stitch" aria-label={about.title} data-about-stats>
        {about.stats.map((stat) => (
          <div class="about__stat-inline" data-about-stat>
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { initAboutIntro } from '../../lib/animations/about/init-about-intro.ts';

  const root = document.querySelector('[data-about-root]');

  if (root instanceof HTMLElement) {
    initAboutIntro(root);
  }
</script>
