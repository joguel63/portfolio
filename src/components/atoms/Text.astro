---
interface Props {
  as?: 'p' | 'span' | 'div';
  size?: 'lead' | 'body' | 'small';
  tone?: 'default' | 'muted';
  className?: string;
}

const {
  as = 'p',
  size = 'body',
  tone = 'default',
  className,
} = Astro.props as Props;

const Tag = as;
---

<Tag class:list={['text', `text--${size}`, tone !== 'default' && `text--${tone}`, className]}>
  <slot />
</Tag>
